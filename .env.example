# ──────────────────────────────────────────────
# LLM APIs
# ──────────────────────────────────────────────
# OpenAI API key for GPT models (primary LLM provider)
OPENAI_API_KEY=
# Anthropic API key for Claude models (secondary LLM provider)
ANTHROPIC_API_KEY=
# Default OpenAI model to use for agent completions
OPENAI_MODEL=gpt-4.1
# Default Anthropic model to use for agent completions
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ──────────────────────────────────────────────
# Embeddings
# ──────────────────────────────────────────────
# Voyage AI API key for generating text embeddings
VOYAGE_API_KEY=
# Voyage embedding model name
VOYAGE_MODEL=voyage-3

# ──────────────────────────────────────────────
# Vector Database
# ──────────────────────────────────────────────
# Qdrant server URL: local (default) or Qdrant Cloud (e.g. https://xxx.qdrant.io)
# When local container fails, set QDRANT_URL + QDRANT_API_KEY to use cloud.
QDRANT_URL=http://localhost:6333
# Qdrant collection name for Ira's knowledge base
QDRANT_COLLECTION=ira_knowledge_v3
# Request timeout in seconds (default 30; avoids hang when Qdrant is slow/unreachable)
# QDRANT_TIMEOUT=30
# Optional: mirror every write to Qdrant Cloud (dual-write). Set both to enable.
# One-time copy: ira qdrant sync-to-cloud. See docs/QDRANT_LOCAL_AND_CLOUD_SYNC.md.
# QDRANT_CLOUD_URL=https://YOUR-CLUSTER.region.aws.cloud.qdrant.io:6333
# QDRANT_CLOUD_API_KEY=

# ──────────────────────────────────────────────
# Knowledge Graph
# ──────────────────────────────────────────────
# Neo4j Bolt protocol URI
NEO4J_URI=bolt://localhost:7687
# Neo4j authentication username
NEO4J_USER=neo4j
# Neo4j authentication password
# Local default matches docker-compose.local.yml (override in production)
NEO4J_PASSWORD=ira_knowledge_graph
# Alternative single-value auth format (user/password). Optional.
# NEO4J_AUTH=neo4j/ira_knowledge_graph

# ──────────────────────────────────────────────
# Relational Database (PostgreSQL for CRM)
# ──────────────────────────────────────────────
# Async PostgreSQL connection string used by SQLAlchemy for CRM data
DATABASE_URL=postgresql+asyncpg://ira:ira@localhost:5432/ira_crm

# ──────────────────────────────────────────────
# Memory
# ──────────────────────────────────────────────
# Mem0 API key for persistent conversational memory
MEM0_API_KEY=

# ──────────────────────────────────────────────
# Redis (caching, message persistence, dedup)
# ──────────────────────────────────────────────
# Redis connection URL (Redis Cloud, local, or any Redis-compatible server)
REDIS_URL=redis://localhost:6379/0

# ──────────────────────────────────────────────
# Google Workspace
# ──────────────────────────────────────────────
# Path to Google OAuth2 service account / client credentials JSON
GOOGLE_CREDENTIALS_PATH=.credentials/credentials.json
# Path to stored OAuth2 token (auto-generated after first auth flow)
GOOGLE_TOKEN_PATH=.credentials/token.json
# Google OAuth2 Client ID
GOOGLE_OAUTH_CLIENT_ID=
# Google OAuth2 Client Secret
GOOGLE_OAUTH_CLIENT_SECRET=
# Docs/Drive/Calendar use token_docs.json (separate from Gmail token). If you add Calendar scope later, delete token_docs.json and re-run to re-authorize.
# Email integration. Mail is sent from the account that authorized the Gmail token.
# Set GOOGLE_IRA_EMAIL to the address you want to send from; the token must be for that account.
# GOOGLE_IRA_EMAIL=rushabh@machinecraft.org
# GOOGLE_TRAINING_EMAIL=
# IRA_EMAIL_MODE=TRAINING
# IRA_EMAIL_POLL=false

# ──────────────────────────────────────────────
# External APIs
# ──────────────────────────────────────────────
# Newsdata.io API key for fetching industry news
NEWSDATA_API_KEY=
# Apollo.io API key for contact/company enrichment (Settings > Integrations > API Keys). Uses credits per call.
# APOLLO_API_KEY=
# Web search (Athena, Gapper, Iris): set at least one for company/news lookups and re-engagement tasks.
# Tavily search API key for web search
TAVILY_API_KEY=
# SearchAPI.io API key for search results
SEARCHAPI_API_KEY=
# Serper.dev API key for Google search results
SERPER_API_KEY=

# ──────────────────────────────────────────────
# PDF.co (PDF generation and extraction)
# ──────────────────────────────────────────────
# PDF.co API key for HTML-to-PDF, text extraction, and table extraction
PDFCO_API_KEY=

# ──────────────────────────────────────────────
# Google Cloud (Document AI, DLP)
# ──────────────────────────────────────────────
# GCP project ID for Document AI and DLP APIs
GOOGLE_CLOUD_PROJECT_ID=
# Document AI processor region (us or eu)
DOCUMENT_AI_LOCATION=us
# Document AI OCR processor ID (general-purpose text extraction)
DOCUMENT_AI_PROCESSOR_ID=
# Document AI Invoice Parser processor ID (structured invoice fields)
DOCUMENT_AI_INVOICE_PROCESSOR_ID=
# Document AI Form Parser processor ID (key-value pairs and tables)
DOCUMENT_AI_FORM_PROCESSOR_ID=

# ──────────────────────────────────────────────
# Langfuse (LLM observability)
# ──────────────────────────────────────────────
# Langfuse public key for tracing
LANGFUSE_PUBLIC_KEY=
# Langfuse secret key for tracing
LANGFUSE_SECRET_KEY=
# Langfuse API base URL
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ──────────────────────────────────────────────
# Helicone (LLM proxy — caching, cost tracking)
# ──────────────────────────────────────────────
# Helicone API key for LLM request proxying (optional, free tier: 100K req/mo)
HELICONE_API_KEY=

# ──────────────────────────────────────────────
# Web scraping (scrape_url: Firecrawl → Jina Reader → Crawl4AI → web_search)
# ──────────────────────────────────────────────
# Firecrawl: best quality (JS, anti-bot). Set for reliable URL→markdown. Free tier: 500 pages/mo.
# https://firecrawl.dev
FIRECRAWL_API_KEY=
# Jina Reader (r.jina.ai): optional. When set, used for better rate limits on URL→markdown.
# JINA_API_KEY=
# Crawl4AI: used when Firecrawl/Jina fail; requires Playwright: poetry run playwright install chromium

# ──────────────────────────────────────────────
# Unstructured.io (document ingestion)
# ──────────────────────────────────────────────
# Unstructured API key for unified document parsing (optional, free tier: 1K pages/mo)
UNSTRUCTURED_API_KEY=
# Unstructured API endpoint URL
UNSTRUCTURED_API_URL=https://api.unstructuredapp.io/general/v0/general

# ──────────────────────────────────────────────
# Sentry (error monitoring)
# ──────────────────────────────────────────────
# Sentry DSN for error tracking and performance monitoring (optional, free tier: 5K errors/mo)
SENTRY_DSN=
# Fraction of requests to trace for performance (0.0 to 1.0)
SENTRY_TRACES_SAMPLE_RATE=0.1

# ──────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────
# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
# Runtime environment (development, staging, production)
ENVIRONMENT=development
# API authentication key (leave empty for open access in development)
API_SECRET_KEY=
# Comma-separated list of allowed CORS origins (e.g. http://localhost:3000 for web-ui).
# Avoid CORS_ORIGINS=* in production when using credentials.
CORS_ORIGINS=http://localhost:3000
# Faithfulness gate: block response when score < this (default 0.3). Lower for draft-style tasks.
# APP__FAITHFULNESS_HARD_THRESHOLD=0.05
# Pipeline timeout (seconds). Presets: 30, 120 (2m), 300 (5m), 600 (10m), 1200 (20m). Future: Athena can choose by request type.
# APP__PIPELINE_TIMEOUT=600
# Per-sub-agent slot (seconds). Each parallel agent has this long to return best answer. Default 90.
# APP__AGENT_TIMEOUT=90
# Max sub-agents running in parallel (e.g. 5). Default 5.
# APP__MAX_PARALLEL_AGENTS=5
# Athena synthesis timeout (seconds): time to package final answer for Cursor/API. Default 90.
# APP__ATHENA_SYNTHESIS_TIMEOUT=90
# Hugging Face hub cache dir (optional). Set when default cache disk is full (e.g. data/.cache/hf or /tmp/ira_hf).
# APP__HF_CACHE_DIR=
# Qdrant API key (optional, for Qdrant Cloud)
QDRANT_API_KEY=
